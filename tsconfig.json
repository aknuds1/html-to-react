{
  "include": ["lib/**/*", "test/**/*"],
  "compilerOptions": {
    "allowJs": true,
    // Generate d.ts files
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "types",
    "declarationMap": true,
    "strict": true,
    "moduleResolution": "node",
    "module": "commonjs",
    "target": "es2018",
    "lib": ["es2018"],
    "types": ["mocha", "node"]
  }
}
